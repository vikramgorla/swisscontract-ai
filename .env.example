# SwissContract — Environment Variables
# Copy to .env.local for local development

# Infomaniak AI — required
# Get your token: https://manager.infomaniak.com → AI Tools → API keys
INFOMANIAK_AI_TOKEN=your_infomaniak_ai_token_here

# Infomaniak AI product ID — required
INFOMANIAK_AI_PRODUCT_ID=your_product_id_here

# Environment behaviour (banner, debug logging) is controlled by Traefik-injected
# request headers (X-Show-Banner, X-Debug-Enabled) — no env vars needed for this.
# See deploy.yml for Traefik middleware labels.
