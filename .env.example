# SwissContract — Environment Variables
# Copy to .env.local for local development

# Infomaniak AI — required
# Get your token: https://manager.infomaniak.com → AI Tools → API keys
INFOMANIAK_AI_TOKEN=your_infomaniak_ai_token_here

# Infomaniak AI product ID — required
INFOMANIAK_AI_PRODUCT_ID=your_product_id_here

# Environment — controls debug logging, robots noindex, and the preprod banner
# Values: "production" | anything else (treated as non-production)
# Injected automatically at deploy time via Docker; do not set in .env.production
NEXT_PUBLIC_ENV=development
