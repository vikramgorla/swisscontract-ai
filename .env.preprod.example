# ── SwissContract Preprod Environment ──────────────────────────────
#
# Copy to .env.local for local preprod testing.
# On Jelastic/deployment, set these as environment variables.

# ── Infomaniak AI (Swiss-sovereign) ──────────────────────────────
# All models run on Infomaniak's OpenAI-compatible API.
# Get your token from: https://manager.infomaniak.com → AI Tools → API keys
#
# Models used in comparison mode:
#   - qwen3 (fast, reliable JSON)
#   - moonshotai/Kimi-K2.5 (Swiss law accuracy)
#   - swiss-ai/Apertus-70B (Swiss-sovereign open model)
#
INFOMANIAK_AI_TOKEN=your_infomaniak_ai_token_here

# ── App Config ───────────────────────────────────────────────────
NEXT_PUBLIC_ENV=preprod
